<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="event_services_action" model="ir.actions.act_window">
        <field name="name">Event services</field>
        <field name="res_model">event.services</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p>
                There is no records for the Event services.
            </p>
        </field>
    </record>

    <!-- tree-->
    <record id="event_services_view_tree" model="ir.ui.view">
        <field name="name">event.services.view.tree</field>
        <field name="model">event.services</field>
        <field name="arch" type="xml">
                <tree string="" decoration-success="status=='Co'" decoration-danger="status=='C'">

                <field name="services" />
                <field name="status" />
                <field name="catring_total"
                    attrs="{'invisible':[('services','!=','Cat')]}" />
                <field name="dec_charges" attrs="{'invisible':[('services','!=','dec')]}" />
                <field name="ph_charges" attrs="{'invisible':[('services','!=','ph')]}" />
                <field name="staff_total" attrs="{'invisible':[('services','!=','st')]}" />
                <field name="sub_total"/>
                <field name="status" string="Status" readonly="True"  />
                <!-- <button name="action_accept"  type="object" title="Accept" icon="fa-check" attrs="{'invisible':[('status','!=',False)]} "  />
                <button name="action_refuse" type="object" title="Refuse" icon="fa-times" attrs="{'invisible':[('status','!=',False)]}"/> -->
            </tree>
        </field>
    </record>

    <!--form-->
    <record id="event_services_view_form" model="ir.ui.view">
        <field name="name">Services</field>
        <field name="model">event.services</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="services" />
                        <field name="vender" />
                        <field name="days" />

                    </group>
                    <group>

                        <field name="seating" attrs="{'invisible':[('services','!=','Cat')]}" />
                        <field name="attendee" attrs="{'invisible':[('services','!=','Cat')]}" />
                        <field name="menue"
                            attrs="{'invisible':[('services','!=','Cat')]}" />
                        <field name="per_person_charges"
                            attrs="{'invisible':[('services','!=','Cat')]}" />
                        <field name="catring_total"
                            attrs="{'invisible':[('services','!=','Cat')]}" />

                        <field name="staff_member"
                            attrs="{'invisible':[('services','!=','st')]}" />
                        <field name="per_person_charges"
                            attrs="{'invisible':[('services','!=','st')]}" />
                        <field name="staff_total" attrs="{'invisible':[('services','!=','st')]}" />
                    </group>
                    <group>
                        <field name="dec_charges" attrs="{'invisible':[('services','!=','dec')]}" />
                        <field name="ph_charges" attrs="{'invisible':[('services','!=','ph')]}" />
                        <field name="status" />
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>